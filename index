<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
  <title>💖 Happy 12th May Dimpi – My Kolija 💖</title>
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Poppins', sans-serif;
      color: #fff;
      overflow-x: hidden;
      position: relative;
      /* 🌟 COUPLE BACKGROUND PHOTO 🌟 */
      background: url('https://i.ibb.co/1YnRjnqb/IMG-20260509-154657.jpg') no-repeat center center fixed;
      background-size: cover;
    }

    body::before {
      content: "";
      position: fixed; top:0; left:0; width:100%; height:100%;
      background: rgba(0,0,0,0.55);
      z-index: 0; pointer-events: none;
    }

    /* ---- falling flowers ---- */
    #falling-flowers {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      z-index: 1; pointer-events: none; overflow: hidden;
    }
    .falling-flower {
      position: absolute; font-size: 24px; opacity: 0.8;
      animation: dropFlower linear infinite;
      filter: drop-shadow(0 0 5px #ff99cc);
    }
    @keyframes dropFlower {
      0% { transform: translateY(-10vh) rotate(0deg); opacity: 0.9; }
      100% { transform: translateY(110vh) rotate(360deg); opacity: 0.3; }
    }

    /* ---- couple silhouette ---- */
    .couple-silhouette {
      position: fixed; bottom: 5%; left: 50%; transform: translateX(-50%);
      font-size: 12rem; opacity: 0.17;
      animation: floatCouple 6s ease-in-out infinite;
      filter: drop-shadow(0 0 30px rgba(255,105,180,0.5));
      z-index: 1; pointer-events: none;
    }
    @keyframes floatCouple {
      0%,100% { transform: translateX(-50%) translateY(0); }
      50% { transform: translateX(-50%) translateY(-20px); }
    }

    /* ---- particles ---- */
    #particles-container {
      position: fixed; top:0; left:0; width:100%; height:100%;
      z-index: 2; pointer-events: none; overflow: hidden;
    }
    .particle {
      position: absolute; border-radius: 50%;
      background: rgba(255, 100, 150, 0.5);
      box-shadow: 0 0 10px rgba(255, 80, 120, 0.6);
      animation: floatParticle linear infinite; opacity: 0;
    }
    @keyframes floatParticle {
      0% { transform: translateY(0) scale(0); opacity:0; }
      10% { opacity:1; }
      90% { opacity:0.4; }
      100% { transform: translateY(-100vh) scale(1.5); opacity:0; }
    }

    .main-wrapper { position: relative; z-index: 3; }

    section {
      min-height: 100vh; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 60px 20px; text-align: center; position: relative;
    }

    h2 {
      font-family: 'Dancing Script', cursive;
      font-size: clamp(2.5rem, 8vw, 4rem); margin-bottom: 30px;
      background: linear-gradient(45deg, #ff9a9e, #fad0c4);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 15px #ff3366);
    }

    .btn {
      background: rgba(255,255,255,0.2); backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.5); padding: 14px 28px;
      border-radius: 40px; font-weight: 600; font-size: 1.2rem;
      color: white; cursor: pointer; transition: 0.3s; margin: 10px;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .btn:hover { background: rgba(255,255,255,0.4); box-shadow: 0 0 30px #ff3366; transform: scale(1.05); }

    /* ---- HERO ---- */
    .hero { background: radial-gradient(ellipse at center, rgba(255,70,130,0.2) 0%, transparent 70%); }
    .hero-title {
      font-family: 'Dancing Script', cursive;
      font-size: clamp(4rem, 12vw, 7rem);
      background: linear-gradient(45deg, #ff9a9e, #fad0c4, #fbc2eb, #a18cd1);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; animation: glowPulse 2s infinite alternate;
    }
    @keyframes glowPulse {
      0% { filter: drop-shadow(0 0 10px #ff3366); }
      100% { filter: drop-shadow(0 0 30px #ff1e56); }
    }
    .hero-sub { font-size: 1.8rem; font-weight: 300; color: #ffe5f0; margin: 15px 0 30px; letter-spacing: 2px; }
    .date-highlight {
      font-size: 2.5rem; font-weight: bold; color: #ffcc00;
      text-shadow: 0 0 20px #ff3366; margin-top: 20px;
      animation: pulseText 1.5s infinite;
    }
    @keyframes pulseText { 0%,100%{transform:scale(1);} 50%{transform:scale(1.05); color:#fff0b3;} }
    .scroll-indicator { font-size: 2rem; color: #ffb3c6; animation: bounce 2s infinite; margin-top: 30px; }
    @keyframes bounce {
      0%,20%,50%,80%,100% { transform: translateY(0); }
      40% { transform: translateY(-20px); }
      60% { transform: translateY(-10px); }
    }

    /* ---- ✨ NEW BIG FRAME (no rotating, no glow) ✨ ---- */
    .photo-frame {
      width: 300px;            /* BIGGER */
      height: 300px;
      border-radius: 50%;
      padding: 10px;
      /* elegant static gradient border */
      background: linear-gradient(135deg, #f8a5c2, #e84393, #c44dff);
      box-shadow: none;        /* NO GLOW */
      animation: none;         /* NO ROTATE */
      margin: 30px auto;
      position: relative;
    }
    .photo-inner {
      width: 100%; height: 100%; border-radius: 50%;
      overflow: hidden; position: relative;
      box-shadow: inset 0 0 30px rgba(0,0,0,0.3); /* subtle inner depth */
    }
    .photo-slide {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      background-size: cover; background-position: center;
      opacity: 0; transition: opacity 1.5s ease-in-out;
    }
    .photo-slide.active { opacity: 1; }

    /* flower ring adjusted for bigger frame */
    .flower-ring {
      position: absolute; top: -25px; left: -25px;
      width: calc(100% + 50px); height: calc(100% + 50px);
      border-radius: 50%; pointer-events: none;
    }
    .flower-petal {
      position: absolute; font-size: 30px;
      animation: petalDance 2s infinite alternate;
      filter: drop-shadow(0 0 8px #ff99cc);
    }
    @keyframes petalDance {
      0% { transform: rotate(0deg) scale(1); }
      100% { transform: rotate(10deg) scale(1.15); }
    }
    .crazy-acc {
      position: absolute; font-size: 2.5rem;
      animation: bounceAcc 1s infinite;
      filter: drop-shadow(0 4px 6px black);
      z-index: 5;
    }
    @keyframes bounceAcc {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    /* ---- BEATING HEART ---- */
    .kolija-heart {
      font-size: 10rem; animation: heartBeat 0.8s infinite;
      filter: drop-shadow(0 0 40px #ff3366); margin: 30px 0; cursor: pointer;
    }
    @keyframes heartBeat {
      0% { transform: scale(1); } 14% { transform: scale(1.3); } 28% { transform: scale(1); }
      42% { transform: scale(1.3); } 70% { transform: scale(1); }
    }
    .kolija-text {
      font-family: 'Dancing Script', cursive; font-size: 3rem;
      background: linear-gradient(45deg, #ff4d6d, #ffb3c6);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; margin-top: 10px;
    }

    /* ---- TIMELINE ---- */
    .timeline { display: flex; flex-direction: column; align-items: center; gap: 40px; max-width: 700px; margin: 40px auto; }
    .timeline-item {
      background: rgba(255,255,255,0.1); backdrop-filter: blur(15px);
      border: 1px solid rgba(255,255,255,0.3); border-radius: 25px;
      padding: 25px; width: 100%; text-align: left; transition: transform 0.3s;
    }
    .timeline-item:hover { transform: translateX(10px); box-shadow: 0 10px 30px rgba(255,70,130,0.4); }
    .timeline-date { font-size: 1.8rem; font-weight: bold; color: #ffb3c6; font-family: 'Dancing Script', cursive; }

    /* ---- CAKE ---- */
    .cake-container { perspective: 800px; margin: 30px auto; }
    .cake { position: relative; width: 240px; height: 260px; transform-style: preserve-3d; transform: rotateX(5deg) rotateY(-10deg); cursor: pointer; transition: transform 0.5s; }
    .cake:hover { transform: rotateX(0deg) rotateY(0deg) scale(1.02); }
    .layer { position: absolute; border-radius: 20px; background: linear-gradient(180deg, #f8a5c2, #e84393); box-shadow: 0 10px 25px rgba(0,0,0,0.5); border: 2px solid #ffb3c6; }
    .layer-bottom { width:200px; height:45px; bottom:20px; left:20px; background:linear-gradient(180deg, #f06292, #c2185b); }
    .layer-middle { width:165px; height:40px; bottom:70px; left:37px; background:linear-gradient(180deg, #f48fb1, #d81b60); }
    .layer-top { width:130px; height:35px; bottom:115px; left:55px; background:linear-gradient(180deg, #f8bbd0, #ad1457); }
    .candle { position:absolute; bottom:150px; left:112px; width:16px; height:32px; background:#fff3e0; border-radius:8px 8px 0 0; z-index:5; }
    .flame { position:absolute; top:-20px; left:-5px; width:26px; height:28px; background:radial-gradient(circle, #ff9800, #ff5722); border-radius:50% 50% 50% 50% / 60% 60% 40% 40%; animation:flicker 0.15s infinite alternate; }
    @keyframes flicker { 0%{transform:scale(1) rotate(-2deg);} 100%{transform:scale(1.1) rotate(3deg);} }
    .frosting { position:absolute; bottom:146px; left:52px; width:136px; height:16px; background:radial-gradient(circle at 30% 30%, #fff, #f8bbd0); border-radius:20px; z-index:4; }
    .cake-message { font-family: 'Dancing Script', cursive; font-size: 2rem; color: #ffe5f0; margin-top: 20px; animation: pulseText 1.5s infinite; }

    /* ---- REASONS ---- */
    .reasons-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 25px; max-width: 900px; margin-top: 30px; }
    .reason-card {
      background: rgba(255,255,255,0.1); backdrop-filter: blur(15px);
      border: 1px solid rgba(255,255,255,0.3); border-radius: 25px;
      padding: 25px; width: 200px; text-align: center; transition: transform 0.3s, box-shadow 0.3s;
    }
    .reason-card:hover { transform: translateY(-10px) scale(1.05); box-shadow: 0 20px 40px rgba(255,70,130,0.5); }
    .reason-icon { font-size: 2.5rem; margin-bottom: 15px; }

    /* ---- GIFTS ---- */
    .gifts-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 30px; margin-top: 40px; }
    .gift-box {
      width: 120px; height: 120px; background: linear-gradient(145deg, #ff6b8b, #c44569);
      border-radius: 25px; display: flex; align-items: center; justify-content: center;
      font-size: 3rem; color: white; cursor: pointer; box-shadow: 0 20px 30px rgba(0,0,0,0.4);
      transition: transform 0.3s; animation: floatGift 3s infinite alternate;
    }
    .gift-box:hover { transform: scale(1.15) rotate(5deg); }
    @keyframes floatGift { 0%{transform: translateY(0);} 100%{transform: translateY(-12px);} }

    /* ---- LOVE NOTE ---- */
    .love-note-card { background: rgba(30,10,40,0.8); backdrop-filter: blur(20px); border: 2px solid #ff85a2; border-radius: 40px; max-width: 500px; padding: 40px; margin: 30px auto; }

    /* ---- confetti ---- */
    .confetti-piece { position: fixed; width: 10px; height: 10px; top: -20px; z-index: 999; animation: confettiFall 3s linear forwards; border-radius: 4px; }
    @keyframes confettiFall { 0%{transform: translateY(0) rotate(0deg); opacity:1;} 100%{transform: translateY(100vh) rotate(720deg); opacity:0;} }

    .music-toggle { position: fixed; bottom: 30px; right: 30px; z-index: 100; background: rgba(0,0,0,0.5); border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: #ffb3c6; cursor: pointer; }

    .popup { position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.7); backdrop-filter: blur(10px); z-index: 1100; display: none; align-items: center; justify-content: center; }
    .popup-content { background: rgba(30,10,40,0.9); border:2px solid #ff85a2; border-radius:40px; padding:40px; max-width:400px; text-align:center; }
  </style>
</head>
<body>
