  <script>
    // ---- falling flowers ----
    const flowersContainer = document.getElementById('falling-flowers');
    const flowerEmojis = ['🌸', '🌺', '🌼', '🌷', '💮', '🌻', '🪷', '🌹'];
    for (let i = 0; i < 60; i++) {
      const flower = document.createElement('span');
      flower.className = 'falling-flower';
      flower.innerHTML = flowerEmojis[Math.floor(Math.random() * flowerEmojis.length)];
      flower.style.left = Math.random() * 100 + '%';
      flower.style.animationDuration = (Math.random() * 10 + 8) + 's';
      flower.style.animationDelay = Math.random() * 10 + 's';
      flower.style.fontSize = (Math.random() * 16 + 18) + 'px';
      flowersContainer.appendChild(flower);
    }

    // ---- particles ----
    function createParticles() {
      const container = document.getElementById('particles-container');
      for (let i=0; i<35; i++) {
        const p = document.createElement('div');
        p.className = 'particle';
        const size = Math.random()*4 + 3;
        p.style.width = size+'px'; p.style.height = size+'px';
        p.style.left = Math.random()*100+'%';
        p.style.bottom = '-40px';
        p.style.animationDuration = Math.random()*10 + 8 + 's';
        p.style.animationDelay = Math.random()*8 + 's';
        container.appendChild(p);
      }
    }
    createParticles();

    // ---- flower ring (adjusted for 300px frame) ----
    function createFlowerRing() {
      const ring = document.getElementById('flowerRing');
      const flowers = ['🌸','🌺','🌼','🌷','💮','🌻','🪷','🌹'];
      const r = 150, cx = 150, cy = 150;  // frame is 300px, ring is 350px (300+50), center is 175, but petals need to be placed on a circle of radius 150 around the 150px point
      for (let i=0; i<14; i++) {
        const angle = (i/14)*2*Math.PI;
        const x = cx + r*Math.cos(angle) - 14;
        const y = cy + r*Math.sin(angle) - 14;
        const petal = document.createElement('span');
        petal.className = 'flower-petal';
        petal.innerHTML = flowers[i%flowers.length];
        petal.style.left = x+'px'; petal.style.top = y+'px';
        petal.style.animationDelay = (i*0.15)+'s';
        ring.appendChild(petal);
      }
    }
    createFlowerRing();

    // ---- PHOTO CROSSFADE AUTOMATIC ----
    const slide1 = document.getElementById('slide1');
    const slide2 = document.getElementById('slide2');
    let currentSlide = 1;
    function switchPhoto() {
      if (currentSlide === 1) {
        slide1.classList.remove('active');
        slide2.classList.add('active');
        currentSlide = 2;
      } else {
        slide2.classList.remove('active');
        slide1.classList.add('active');
        currentSlide = 1;
      }
    }
    setInterval(switchPhoto, 4000);

    // ---- cake interaction ----
    let bite = 0;
    const cakeEl = document.getElementById('cakeElement');
    const flame = document.getElementById('flame');
    const candle = document.getElementById('candle');
    const cakeMsg = document.getElementById('cakeMessage');
    document.getElementById('cakeContainer').addEventListener('click', (e) => {
      if (e.target.tagName === 'BUTTON') return;
      bite++;
      if (bite === 1) {
        flame.style.display = 'none'; cakeMsg.textContent = '💨 Candles blown! Make a wish, Dimpi. Click to eat.';
        launchMiniConfetti(15);
      } else if (bite === 2) {
        cakeEl.style.transform = 'rotateX(5deg) rotateY(-10deg) scale(0.9)';
        cakeMsg.textContent = '😋 Mmm first bite! So delicious. Another, Kolija?';
        launchMiniConfetti(15);
      } else if (bite === 3) {
        cakeEl.style.transform = 'rotateX(5deg) rotateY(-10deg) scale(0.8)';
        cakeMsg.textContent = '🤤 Almost gone...';
        launchMiniConfetti(20);
      } else {
        cakeEl.style.transform = 'scale(0.1)'; cakeEl.style.opacity = '0';
        candle.style.display = 'none'; cakeMsg.textContent = '🎉 Cake finished! My love for you is forever 💖';
        document.getElementById('surpriseMessage').innerHTML = '🍰 You ate the whole cake, just like you ate my heart, Kolija!';
        launchConfetti();
        setTimeout(() => {
          cakeEl.style.transform = 'rotateX(5deg) rotateY(-10deg) scale(1)';
          cakeEl.style.opacity = '1'; flame.style.display = 'block';
          candle.style.display = 'block'; cakeMsg.textContent = 'Click cake to eat! 🍰';
          bite=0;
        }, 3000);
      }
    });
    document.getElementById('resetCakeBtn').addEventListener('click', (e) => {
      e.stopPropagation();
      bite=0; cakeEl.style.transform = 'rotateX(5deg) rotateY(-10deg) scale(1)';
      cakeEl.style.opacity = '1'; flame.style.display = 'block';
      candle.style.display = 'block'; cakeMsg.textContent = 'Click cake to eat! 🍰';
    });

    // ---- reasons ----
    const reasons = [
      {icon:'😂', text:'Your laugh is my favorite sound, Dimpi'},
      {icon:'🌮', text:'You steal my fries and I still love you, Kolija'},
      {icon:'🎤', text:'Our shower duets are Grammy worthy'},
      {icon:'🐒', text:'You’re perfectly weird, just like me'},
      {icon:'💪', text:'You make me stronger every day'},
      {icon:'🌙', text:'You’re the dream I never want to leave'}
    ];
    const grid = document.getElementById('reasonsGrid');
    reasons.forEach(r => {
      const card = document.createElement('div');
      card.className = 'reason-card';
      card.innerHTML = `<div class="reason-icon">${r.icon}</div><p style="font-size:1.2rem;">${r.text}</p>`;
      grid.appendChild(card);
    });

    // ---- gifts ----
    function openGift(msg) {
      document.getElementById('giftMessage').textContent = msg;
      document.getElementById('giftPopup').style.display = 'flex';
      launchMiniConfetti(10);
    }

    // ---- confetti ----
    function launchMiniConfetti(n) {
      for (let i=0;i<n;i++) {
        const c = document.createElement('div'); c.className='confetti-piece';
        c.style.left = Math.random()*100+'%';
        c.style.background = `hsl(${Math.random()*360},80%,70%)`;
        c.style.animationDuration = (Math.random()*2+1.5)+'s';
        document.body.appendChild(c);
        setTimeout(()=>c.remove(), 2500);
      }
    }
    function launchConfetti() {
      for (let i=0;i<100;i++) {
        const c = document.createElement('div'); c.className='confetti-piece';
        c.style.left = Math.random()*100+'%';
        c.style.background = `hsl(${Math.random()*360},90%,65%)`;
        c.style.animationDuration = (Math.random()*3+2)+'s';
        c.style.width = (Math.random()*12+6)+'px'; c.style.height = (Math.random()*12+6)+'px';
        document.body.appendChild(c);
        setTimeout(()=>c.remove(), 3500);
      }
    }
    document.getElementById('confettiBtn').addEventListener('click', () => {
      launchConfetti();
      document.getElementById('surpriseMessage').innerHTML = '🎉🎊 HAPPY 12th MAY, MY KOLIJA, MY DIMPI! 🎊🎉';
    });

    // ---- kolija heart ----
    document.getElementById('kolijaHeart').addEventListener('click', () => {
      launchMiniConfetti(30);
      document.getElementById('surpriseMessage').innerHTML = '💓 Kolija, every beat is for you! 💓';
      const heart = document.getElementById('kolijaHeart');
      heart.style.animation = 'none'; heart.offsetHeight; heart.style.animation = 'heartBeat 0.8s infinite';
    });

    // ---- YouTube Music Auto‑play ----
    let player;
    let musicPlaying = false;
    const musicToggle = document.getElementById('musicToggle');

    const tag = document.createElement('script');
    tag.src = "https://www.youtube.com/iframe_api";
    const firstScriptTag = document.getElementsByTagName('script')[0];
    firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

    function onYouTubeIframeAPIReady() {
      player = new YT.Player('youtube-player', {
        videoId: 'f5-IY_Ja1RM',
        playerVars: {
          'autoplay': 1, 'controls': 0, 'showinfo': 0, 'rel': 0,
          'loop': 1, 'playlist': 'f5-IY_Ja1RM', 'mute': 0
        },
        events: {
          'onReady': onPlayerReady,
          'onStateChange': onPlayerStateChange
        }
      });
    }
    function onPlayerReady(event) {
      player.playVideo();
      musicToggle.style.display = 'block';
    }
    function onPlayerStateChange(event) {
      if (event.data == YT.PlayerState.PLAYING) {
        musicPlaying = true; musicToggle.innerHTML = '<i class="fas fa-pause"></i>';
      } else if (event.data == YT.PlayerState.PAUSED || event.data == YT.PlayerState.ENDED) {
        musicPlaying = false; musicToggle.innerHTML = '<i class="fas fa-music"></i>';
      }
    }
    musicToggle.addEventListener('click', () => {
      if (musicPlaying) { player.pauseVideo(); } else { player.playVideo(); }
    });

    window.addEventListener('load', () => {
      document.getElementById('surpriseMessage').innerHTML = '💫 Scroll down, Kolija… our love story begins 💫';
    });
  </script>
</body>
</html>